# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env & secrets — .env.example stays committed
.env
.env.local
.env*.local

# supabase local
supabase/.temp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright MCP test artifacts
.playwright-mcp/

# font archives (extracted into src/app/fonts)
*.zip
# local screenshots
/*.jpeg
/*.png

# local design reference screenshots
/design-refs/

# useAnimations icon pack (raw download; used .json extracted into src/lib/lottie/)
useanimations/
